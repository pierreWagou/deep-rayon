{
  "name": "vusion_dbt_pipeline",
  "description": "Databricks job to execute the Vusion dbt transformation pipeline: run models, test data quality, generate documentation, and optimize Delta tables.",
  "tags": {
    "project": "vusion",
    "team": "data-engineering",
    "environment": "production"
  },
  "schedule": {
    "quartz_cron_expression": "0 0 3 * * ?",
    "timezone_id": "Europe/Paris",
    "pause_status": "UNPAUSED"
  },
  "max_concurrent_runs": 1,
  "timeout_seconds": 7200,
  "email_notifications": {
    "on_failure": ["data-engineering@vusion.com"],
    "on_start": [],
    "on_success": []
  },
  "tasks": [
    {
      "task_key": "dbt_run",
      "description": "Execute dbt models (staging → silver → gold)",
      "notebook_task": {
        "notebook_path": "/Repos/vusion/dbt_project/databricks/dbt_runner",
        "base_parameters": {
          "dbt_command": "run",
          "profiles_dir": "/Repos/vusion/dbt_project",
          "project_dir": "/Repos/vusion/dbt_project",
          "target": "prod"
        }
      },
      "new_cluster": {
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 2,
        "spark_conf": {
          "spark.databricks.delta.optimizeWrite.enabled": "true",
          "spark.databricks.delta.autoCompact.enabled": "true"
        },
        "azure_attributes": {
          "first_on_demand": 1,
          "availability": "ON_DEMAND_AZURE"
        }
      },
      "timeout_seconds": 3600,
      "max_retries": 2,
      "min_retry_interval_millis": 60000,
      "retry_on_timeout": true
    },
    {
      "task_key": "dbt_test",
      "description": "Run dbt data quality tests (schema + custom)",
      "depends_on": [
        {"task_key": "dbt_run"}
      ],
      "notebook_task": {
        "notebook_path": "/Repos/vusion/dbt_project/databricks/dbt_runner",
        "base_parameters": {
          "dbt_command": "test",
          "profiles_dir": "/Repos/vusion/dbt_project",
          "project_dir": "/Repos/vusion/dbt_project",
          "target": "prod"
        }
      },
      "existing_cluster_id": "${var.shared_cluster_id}",
      "timeout_seconds": 1800,
      "max_retries": 1,
      "min_retry_interval_millis": 30000,
      "retry_on_timeout": false
    },
    {
      "task_key": "dbt_docs_generate",
      "description": "Generate dbt documentation catalog",
      "depends_on": [
        {"task_key": "dbt_test"}
      ],
      "notebook_task": {
        "notebook_path": "/Repos/vusion/dbt_project/databricks/dbt_runner",
        "base_parameters": {
          "dbt_command": "docs generate",
          "profiles_dir": "/Repos/vusion/dbt_project",
          "project_dir": "/Repos/vusion/dbt_project",
          "target": "prod"
        }
      },
      "existing_cluster_id": "${var.shared_cluster_id}",
      "timeout_seconds": 900,
      "max_retries": 1,
      "min_retry_interval_millis": 30000,
      "retry_on_timeout": false
    },
    {
      "task_key": "optimize_tables",
      "description": "Run OPTIMIZE + Z-ORDER on Delta tables for query performance",
      "depends_on": [
        {"task_key": "dbt_docs_generate"}
      ],
      "notebook_task": {
        "notebook_path": "/Repos/vusion/dbt_project/databricks/optimize_tables",
        "base_parameters": {
          "catalog": "vusion_catalog",
          "schema_prefix": "retail"
        }
      },
      "existing_cluster_id": "${var.shared_cluster_id}",
      "timeout_seconds": 1800,
      "max_retries": 1,
      "min_retry_interval_millis": 60000,
      "retry_on_timeout": true
    }
  ],
  "job_clusters": [
    {
      "job_cluster_key": "dbt_cluster",
      "new_cluster": {
        "spark_version": "14.3.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 2,
        "spark_conf": {
          "spark.databricks.delta.optimizeWrite.enabled": "true",
          "spark.databricks.delta.autoCompact.enabled": "true"
        }
      }
    }
  ],
  "format": "MULTI_TASK"
}
