{
  "name": "vusion_dbt_pipeline",
  "description": "Vusion dbt transformation pipeline: build models, test data quality, generate documentation, and optimize Delta tables. Uses Databricks-native dbt_task (recommended since 2023.2+) instead of a notebook wrapper for cleaner dependency management and built-in logging.",
  "tags": {
    "project": "vusion",
    "team": "data-engineering"
  },
  "schedule": {
    "quartz_cron_expression": "0 0 3 * * ?",
    "timezone_id": "Europe/Paris",
    "pause_status": "UNPAUSED"
  },
  "max_concurrent_runs": 1,
  "email_notifications": {
    "on_failure": ["data-engineering@vusion.com"]
  },
  "job_clusters": [
    {
      "job_cluster_key": "dbt_cli",
      "new_cluster": {
        "spark_version": "16.4.x-scala2.12",
        "node_type_id": "Standard_DS3_v2",
        "num_workers": 0,
        "spark_conf": {
          "spark.master": "local[*, 4]",
          "spark.databricks.cluster.profile": "singleNode"
        },
        "custom_tags": {
          "ResourceClass": "SingleNode"
        }
      }
    }
  ],
  "tasks": [
    {
      "task_key": "dbt_run",
      "description": "Execute dbt models (bronze, silver, gold)",
      "job_cluster_key": "dbt_cli",
      "dbt_task": {
        "project_directory": "/Workspace/dbt_project",
        "commands": ["dbt deps", "dbt seed", "dbt run --vars '{\"data_path\": \"<data_path>\"}'"],
        "warehouse_id": "<warehouse_id>"
      },
      "libraries": [
        {"pypi": {"package": "dbt-databricks>=1.9.0,<2.0.0"}}
      ],
      "max_retries": 2,
      "min_retry_interval_millis": 60000,
      "retry_on_timeout": true
    },
    {
      "task_key": "dbt_test",
      "description": "Run dbt data quality tests (schema + custom)",
      "depends_on": [{"task_key": "dbt_run"}],
      "job_cluster_key": "dbt_cli",
      "dbt_task": {
        "project_directory": "/Workspace/dbt_project",
        "commands": ["dbt test --vars '{\"data_path\": \"<data_path>\"}'"],
        "warehouse_id": "<warehouse_id>"
      },
      "libraries": [
        {"pypi": {"package": "dbt-databricks>=1.9.0,<2.0.0"}}
      ],
      "max_retries": 1,
      "min_retry_interval_millis": 30000,
      "retry_on_timeout": false
    },
    {
      "task_key": "dbt_docs_generate",
      "description": "Generate dbt documentation catalog",
      "depends_on": [{"task_key": "dbt_test"}],
      "job_cluster_key": "dbt_cli",
      "dbt_task": {
        "project_directory": "/Workspace/dbt_project",
        "commands": ["dbt docs generate --vars '{\"data_path\": \"<data_path>\"}'"],
        "warehouse_id": "<warehouse_id>"
      },
      "libraries": [
        {"pypi": {"package": "dbt-databricks>=1.9.0,<2.0.0"}}
      ],
      "max_retries": 1,
      "min_retry_interval_millis": 30000,
      "retry_on_timeout": false
    },
    {
      "task_key": "optimize_tables",
      "description": "Run OPTIMIZE + Z-ORDER on Delta tables for query performance",
      "depends_on": [{"task_key": "dbt_docs_generate"}],
      "job_cluster_key": "dbt_cli",
      "dbt_task": {
        "project_directory": "/Workspace/dbt_project",
        "commands": ["dbt run-operation generate_optimization_statements"],
        "warehouse_id": "<warehouse_id>"
      },
      "libraries": [
        {"pypi": {"package": "dbt-databricks>=1.9.0,<2.0.0"}}
      ],
      "max_retries": 1,
      "min_retry_interval_millis": 60000,
      "retry_on_timeout": true
    }
  ]
}
