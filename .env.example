# .env.example — copy to .env and fill in real values
# Loaded by mise via _.file = ".env" (see mise.toml)

# Databricks credentials (alternative to ~/.databrickscfg profile)
# DATABRICKS_HOST=https://your-workspace.azuredatabricks.net
# DATABRICKS_TOKEN=dapi...

# Databricks bundle variables (BUNDLE_VAR_ prefix is read by `databricks bundle deploy`)
# See databricks.yml for variable declarations.
BUNDLE_VAR_warehouse_id=
BUNDLE_VAR_data_path=/FileStore/data
# For production (Azure Blob Storage):
# BUNDLE_VAR_data_path=abfss://<container>@<storage_account>.dfs.core.windows.net/data
